<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>M.K Brasil - Viagens Internacionais</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --primary: #FF6B00;
            --dark: #1A1A1A;
        }
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: #333;
        }
        
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(26, 26, 26, 0.95);
            z-index: 1000;
            padding: 1rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .logo {
            font-size: 1.8rem;
            font-weight: bold;
            color: var(--primary);
        }
        
        .nav-links a {
            color: white;
            text-decoration: none;
            margin-left: 2rem;
            font-weight: 500;
        }
        
        .nav-links a:hover {
            color: var(--primary);
        }
        
        /* Hero */
        header {
            background: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.65)), 
                        url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4') center/cover no-repeat;
            height: 100vh;
            color: white;
            display: flex;
            align-items: center;
            text-align: center;
        }
        
        .hero-content {
            max-width: 900px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        .hero-content h1 {
            font-size: 3.8rem;
            margin-bottom: 1rem;
        }
        
        .hero-content p {
            font-size: 1.4rem;
            margin-bottom: 2.5rem;
        }
        
        .btn {
            background: var(--primary);
            color: white;
            padding: 15px 35px;
            border: none;
            border-radius: 50px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }
        
        .btn:hover {
            background: #e55a00;
            transform: translateY(-5px);
        }
        
        /* Seção de Destinos */
        .destinos {
            padding: 100px 5%;
            background: #f8f9fa;
        }
        
        .section-title {
            text-align: center;
            font-size: 2.8rem;
            margin-bottom: 3rem;
            color: var(--dark);
        }
        
        .destinos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
            gap: 2.5rem;
        }
        
        .card {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.12);
            transition: all 0.4s;
        }
        
        .card:hover {
            transform: translateY(-15px);
        }
        
        .card img {
            width: 100%;
            height: 260px;
            object-fit: cover;
        }
        
        .card-content {
            padding: 1.8rem;
        }
        
        .card h3 {
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
        }
        
        .flag {
            font-size: 2.2rem;
            margin-bottom: 10px;
        }
        
        .preco {
            color: var(--primary);
            font-size: 1.6rem;
            font-weight: bold;
            margin: 1rem 0;
        }
        
        .info {
            font-size: 1.05rem;
            color: #555;
            margin-bottom: 1.2rem;
        }
        
        footer {
            background: var(--dark);
            color: white;
            padding: 70px 5% 30px;
            text-align: center;
        }
        
        .footer-content {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 3rem;
            margin-bottom: 3rem;
        }
    </style>
</head>
<body>

    <!-- Navegação -->
    <nav>
        <div class="logo">M.K Brasil</div>
        <div class="nav-links">
            <a href="#">Início</a>
            <a href="#">Destinos</a>
            <a href="#">Pacotes</a>
            <a href="#">Promoções</a>
            <a href="#">Contato</a>
        </div>
    </nav>

    <!-- Hero -->
    <header>
        <div class="hero-content">
            <h1>Viagens Internacionais com Sotaque Brasileiro</h1>
            <p>Conheça o mundo com segurança, conforto e os melhores preços do Brasil</p>
            <button class="btn">Ver todos os destinos</button>
        </div>
    </header>

    <!-- Destinos em Destaque -->
    <section class="destinos">
        <h2 class="section-title">Destinos Internacionais em Destaque</h2>
        
        <div class="destinos-grid">

            <!-- França -->
            <div class="card">
                <img src="https://images.unsplash.com/photo-1502602898657-3e91760cbb34" alt="Paris">
                <div class="card-content">
                    <div class="flag">🇫🇷</div>
                    <h3>França</h3>
                    <p class="info">Paris • 7 noites • Aéreo + Hotel 4★</p>
                    <div class="preco">A partir de R$ 6.890</div>
                    <button class="btn" style="width: 100%;">Ver Pacotes para França</button>
                </div>
            </div>

            <!-- Japão -->
            <div class="card">
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTskHjtYZvlU2_ld4tj8Zk9K2s3XPBFSGWNZQ&s" alt="Japão">
                <div class="card-content">
                    <div class="flag">🇯🇵</div>
                    <h3>Japão</h3>
                    <p class="info">Tóquio + Kyoto • 9 noites • Aéreo + Hotéis</p>
                    <div class="preco">A partir de R$ 12.490</div>
                    <button class="btn" style="width: 100%;">Ver Pacotes para Japão</button>
                </div>
            </div>

            <!-- Estados Unidos -->
            <div class="card">
                <img src="https://images.unsplash.com/photo-1496442226666-8d4d0e62e6e9" alt="Nova York">
                <div class="card-content">
                    <div class="flag">🇺🇸</div>
                    <h3>Estados Unidos</h3>
                    <p class="info">Nova York • 8 noites • Aéreo + Hotel em Manhattan</p>
                    <div class="preco">A partir de R$ 8.790</div>
                    <button class="btn" style="width: 100%;">Ver Pacotes para EUA</button>
                </div>
            </div>

        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <div>
                <h2 style="color: var(--primary);">M.K Brasil</h2>
                <p>Realizando sonhos de viagem desde 2018</p>
                <p style="margin-top: 15px; font-size: 2.5rem;">🇧🇷</p>
            </div>
            <div>
                <h3>Contato</h3>
                <p><i class="fas fa-phone"></i> (11) 4002-8922</p>
                <p><i class="fab fa-whatsapp"></i> (11) 98765-4321</p>
                <p><i class="fas fa-envelope"></i> M.Kbrasil.com.br</p>
            </div>
            <div>
                <h3>Destinos</h3>
                <p>Europa • Ásia • América do Norte • Oriente Médio • Oceania</p>
            </div>
        </div>
        <p style="opacity: 0.6; font-size: 0.9rem;">
            © 2026 M.K Brasil - Agência de Viagens Internacionais • São Paulo, Brasil
        </p>
    </footer>

</body>
</html>
