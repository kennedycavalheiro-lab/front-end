<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Título da Página</title>
    <style>
        .campo{
            background-color: darkcyan;
            border:4px solid blue;
        }
        .botao{
            width:5% ;
            height: 3%;
            background-color: blue;
            border:4px solid darkcyan ;
        }
        .botaox{
            width:5% ;
            height: 3%;
            background-color: rgb(0, 229, 255);
            border:4px solid rgb(15, 83, 77) ;
        }
        .botao3{
            width:13% ;
            height: 3%;
            background-color: rgb(105, 178, 186);
            border:4px solid rgb(98, 231, 220) ;
        }
        .botao4{
            width:14% ;
            height: 3%;
            background-color: rgb(54, 56, 127);
            border:4px solid rgb(0, 69, 80) ;
        }
    </style>
    <script>
        function adicionar(valor){
            document.getElementById("campo").value += valor;
        }
        function limpar(){
            document.getElementById("campo").value += "";

        }
    </script>
</head>
<body>
   <fieldset>
      <legend>calculadora do 2°A</legend>
      <input type="text" id="campo" class="campo"><br><br>
      <button class="botao"onclick="adicionar('1')">1</button>
      <button class="botao"onclick="adicionar('2')">2</button>
      <button class="botao"onclick="adicionar('3')">3</button>
      <button class="botaox"onclick="adicionar('*')">x</button>
      <button class="botaox"onclick="adicionar('^')">^</button>
      <br>
      <button class="botao"onclick="adicionar('4')">4</button>
      <button class="botao"onclick="adicionar('5')">5</button>
      <button class="botao"onclick="adicionar('6')">6</button>
      <button class="botaox"onclick="adicionar('/')">/</button>
      <button class="botaox"onclick="adicionar('(')">(</button>
      <br>
      <button class="botao"onclick="adicionar('7')">7</button>
      <button class="botao"onclick="adicionar('8')">8</button>
      <button class="botao"onclick="adicionar('9')">9</button>
      <button class="botaox"onclick="adicionar('+')">+</button>
      <button class="botaox"onclick="adicionar(')')">)</button>
      <br>
      <button class="botaox"onclick="adicionar('.')">*</button>
      <button class="botao"onclick="adicionar('0')">0</button>
      <button class="botaox"onclick="adicionar('#')">#</button>
      <button class="botaox"onclick="adicionar('-')">-</button>
      <button class="botaox"onclick="adicionar('%')">%</button>
      <br>
      <button class="botao4"onclick="limpar()">c</button>
      <button class="botao3"onclick="adicionar('')">=</button>
   </fieldset> 
</body>
</html>
